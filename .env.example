# LLM Configuration

# Provider: 'gemini' | 'openai'
VITE_LLM_PROVIDER=gemini

# Base URL (Optional, defaults to official endpoints if empty)
# For Gemini: Leave empty or use specific proxy
# For OpenAI: https://api.openai.com/v1 or custom proxy
VITE_LLM_BASE_URL=

# Model Name
# Gemini example: gemini-3-flash-preview
# OpenAI example: gpt-5.2
VITE_LLM_MODEL=gemini-3-flash-preview

# API Key
VITE_LLM_API_KEY=
